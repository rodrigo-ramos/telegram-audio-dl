# .env.example — telegram-audio-dl
#
# Copia este archivo a `.env` y rellena con tus valores.
# El archivo `.env` está en `.gitignore` y nunca se commitea.
#
# Si usas el wrapper `bin/aut-03-run.sh` con Vaultwarden/Bitwarden, los tres
# campos sensibles (TELEGRAM_API_ID, TELEGRAM_API_HASH, TELEGRAM_PHONE) los
# inyecta el wrapper desde el vault y NO hace falta ponerlos aquí.

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS — credenciales de la cuenta personal de Telegram
# Obtenlos en https://my.telegram.org → API development tools
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Número en formato internacional E.164, ej. +1234567890
TELEGRAM_PHONE=

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN — siempre en .env (no son secrets)
# ─────────────────────────────────────────────────────────────────────────────

# Nombre del archivo de sesión de Telethon (sin extensión).
TELEGRAM_SESSION=telegram_audio_dl

# Carpeta raíz para descargas. Si vacío, usa ~/Downloads.
DOWNLOAD_ROOT=

# Nivel de log: INFO (default) o DEBUG (verboso).
LOG_LEVEL=INFO
